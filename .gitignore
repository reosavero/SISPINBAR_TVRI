# ============================================
# .gitignore - SISPINBAR TVRI Jawa Timur
# ============================================

# Dependencies
node_modules/
dist/
build/

# Environment (SENSITIVE: contains DB credentials, JWT secret, SMTP password)
.env
.env.local
.env.production
.env.*

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Logs
*.log
npm-debug.log*
logs/

# ============================================
# SENSITIVE DATA - DO NOT COMMIT
# ============================================

# Database dumps (contains user data, passwords, etc.)
sispinbar_full.sql
*.sql.dump
*.sql.bak

# Seed data (contains hashed passwords)
backend/database/seed.sql

# Test files (may contain test credentials)
backend/test-*.js

# Uploads - user data (photos, documents)
backend/uploads/avatars/
backend/uploads/barang/
backend/uploads/peminjaman/
backend/uploads/pengembalian/
backend/uploads/**/*.jpg
backend/uploads/**/*.png
backend/uploads/**/*.jpeg
backend/uploads/**/*.gif
backend/uploads/**/*.webp
backend/uploads/**/*.pdf

# Keep .gitkeep for directory structure
!backend/uploads/**/.gitkeep
!backend/uploads/.gitkeep

# Artifacts
backend/nul
*.nul

# Temp files
*.tmp
*.bak
*~